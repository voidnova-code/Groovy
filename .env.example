# Django Secret Key - IMPORTANT: Change this in production!
SECRET_KEY=django-change-this-to-a-random-secret-key-in-production

# Set to False in production
DEBUG=False

# Allowed hosts - add your Vercel domain here after deployment
# Example: ALLOWED_HOSTS=groovy-tictactoe.vercel.app
ALLOWED_HOSTS=groovy-tictactoe.vercel.app,localhost,127.0.0.1

# PostgreSQL Database URL - Use Supabase (Recommended!)
# 1. Go to https://supabase.com
# 2. Sign up with GitHub
# 3. Create new project
# 4. Go to Settings → Database → Copy Connection String
# Format: postgresql://postgres:PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres

# Alternative providers: Neon (neon.tech), Railway (railway.app), AWS RDS

# Razorpay Key ID for donations
RAZORPAY_KEY_ID=rzp_test_GrDJB7qqAMqF0yW
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Google OAuth Configuration (required for Google login)
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create OAuth 2.0 credentials (Web application)
# 2. Add authorized redirect URIs: https://yourapp.vercel.app/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
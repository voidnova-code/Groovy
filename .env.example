# Django Secret Key - IMPORTANT: Change this in production!
SECRET_KEY=django-change-this-to-a-random-secret-key-in-production

# Set to False in production
DEBUG=False

# Allowed hosts - add your Render domain here after deployment
# Example: ALLOWED_HOSTS=groovy-tictactoe.onrender.com
ALLOWED_HOSTS=groovy-tictactoe.onrender.com,localhost,127.0.0.1

# PostgreSQL Database URL - Get from Render dashboard
# Format: postgres://username:password@host:port/database_name
DATABASE_URL=postgres://your_user:your_password@your_host:5432/your_database

# Razorpay Key ID for donations
RAZORPAY_KEY_ID=rzp_test_GrDJB7qqAMqF0yW
RAZORPAY_KEY_SECRET=your_razorpay_secret